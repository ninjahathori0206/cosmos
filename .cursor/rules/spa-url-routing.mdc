## Client-Side Router

### Minimal vanilla implementation
```js
const routes = {
  '/':          () => showPage('home'),
  '/about':     () => showPage('about'),
  '/products':  () => showPage('products'),
};

function resolve(pathname = window.location.pathname) {
  // Exact match
  const handler = routes[pathname];
  if (handler) return handler();

  // Prefix match (longest wins, for nested routes)
  const match = Object.keys(routes)
    .filter(r => pathname.startsWith(r) && r !== '/')
    .sort((a, b) => b.length - a.length)[0];

  if (match) return routes[match]();

  routes['/'](); // fallback to home / 404 page
}

// Initial load
document.addEventListener('DOMContentLoaded', () => resolve());

// Browser back / forward
window.addEventListener('popstate', () => resolve());
```

### Navigation — always use pushState
```js
function navigate(path) {
  history.pushState({}, '', path);
  resolve(path);
}

// Intercept clicks on SPA links
document.addEventListener('click', (e) => {
  const link = e.target.closest('[data-route]');
  if (!link) return;
  e.preventDefault();
  navigate(link.dataset.route);
});
```

