NODE_ENV=development
PORT=4000

# MSSQL connection
DB_HOST=localhost
DB_PORT=1433
DB_NAME=CosmosERP
DB_USER=cosmos_app
DB_PASSWORD=CHANGE_ME

# Auth
JWT_SECRET=CHANGE_ME_JWT_SECRET
JWT_EXPIRES_IN=1d
API_KEY=CHANGE_ME_API_KEY

# Optional AES-256-CBC encryption (32-byte key, 16-byte IV derived internally)
ENCRYPTION_KEY=CHANGE_ME_ENCRYPTION_KEY_32_BYTES

# Logging
LOG_DIRECTORY=./logs

